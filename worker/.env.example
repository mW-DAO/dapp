# Database Configuration
# Necessary for Prisma Client to connect to the database
DATABASE_URL="postgresql://user:password@localhost:5432/mw_dao?schema=public"

# Blockchain Configuration
# Chain ID (56 for BSC Mainnet, 97 for BSC Testnet, 1 for Ethereum Mainnet)
CHAIN_ID=56

# RPC Node URL (e.g., https://bsc-dataseed.binance.org/)
RPC_URL="https://bsc-dataseed.binance.org/"

# Admin Wallet Private Key
# Used for signing transactions (settleRewards, recordAction)
# Must start with 0x
ADMIN_PRIVATE_KEY="0x..."

# Optional: Logger Level (info, debug, error)
LOG_LEVEL="info"
